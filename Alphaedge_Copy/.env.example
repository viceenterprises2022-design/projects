# AlphaCopy Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Hyperliquid ───────────────────────────────────────────────────────────
HL_ACCOUNT_ADDRESS=0x...          # Your main HL wallet address
HL_PRIVATE_KEY=0x...              # API wallet private key (NOT main wallet)
# Generate API wallet at: https://app.hyperliquid.xyz/API

# ── Binance ───────────────────────────────────────────────────────────────
BINANCE_API_KEY=...
BINANCE_API_SECRET=...
# Enable Futures + Read access. Disable withdrawals!

# ── Polymarket ────────────────────────────────────────────────────────────
POLY_PRIVATE_KEY=0x...            # Polygon wallet private key
POLY_FUNDER_ADDRESS=0x...         # Wallet holding USDC collateral
# Fund with USDC on Polygon (not Ethereum)

# ── Notifications ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
